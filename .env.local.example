# Firebase Console > Project settings > General > Your apps > SDK setup and configuration
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Console > Realtime Database > copy the database URL shown at the top
NEXT_PUBLIC_FIREBASE_DATABASE_URL=

# Firebase Console > App Check > register this app with reCAPTCHA v3.
# Recommended before a public release — see README "公開前に" section.
# Leave blank for local development if you haven't set it up yet.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Production URL of the deployed site (no trailing slash), e.g.
# https://never-note.example.com — used to build absolute OGP/Twitter
# Card image URLs and the sitemap. Required at BUILD time since this
# is a static export; changing it means redeploying. Safe to leave
# blank for local development (falls back to http://localhost:3000).
NEXT_PUBLIC_SITE_URL=
